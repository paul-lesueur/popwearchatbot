<h1 class="devise-card__title">Nouveau mot de passe</h1>

<p class="devise-card__subtitle">Choisissez un nouveau mot de passe</p>

<%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
  <%= f.error_notification %>

  <%= f.input :reset_password_token, as: :hidden %>
  <%= f.full_error :reset_password_token %>

  <div class="form-inputs">
    <%= f.input :password,
                label: false,
                required: true,
                autofocus: true,
                placeholder: "Nouveau mot de passe",
                hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
                input_html: { autocomplete: "new-password" } %>
    <%= f.input :password_confirmation,
                label: false,
                required: true,
                placeholder: "Confirmer le mot de passe",
                input_html: { autocomplete: "new-password" } %>
  </div>

  <div class="form-actions">
    <%= f.button :submit, "Modifier mon mot de passe" %>
  </div>
<% end %>

<p class="devise-card__footer">
  <%= link_to "Retour à la connexion", new_session_path(resource_name) %>
</p>
