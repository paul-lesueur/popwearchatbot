<div class="profile-page">
  <div class="profile-card">
    <h1 class="profile-title">Mon profil</h1>
    <p class="profile-subtitle">Gérez vos informations personnelles et professionnelles</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "profile-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <!-- ====== SECTION 1 : INFOS PERSONNELLES ====== -->
      <section class="profile-section">
        <h2 class="profile-section-title">Mes infos personnelles</h2>

        <div class="form-row">
          <div class="form-group">
            <%= f.label :first_name, "Prénom", class: "form-label" %>
            <%= f.text_field :first_name, class: "form-control", placeholder: "Marie" %>
          </div>
          <div class="form-group">
            <%= f.label :last_name, "Nom", class: "form-label" %>
            <%= f.text_field :last_name, class: "form-control", placeholder: "Dupont" %>
          </div>
        </div>

        <div class="form-group">
          <%= f.label :email, "Adresse email", class: "form-label" %>
          <%= f.email_field :email, class: "form-control", autocomplete: "email" %>
        </div>

        <div class="form-group">
          <%= f.label :password, "Nouveau mot de passe", class: "form-label" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control", placeholder: "Laisser vide pour ne pas changer" %>
          <% if @minimum_password_length %>
            <small class="form-hint"><%= @minimum_password_length %> caractères minimum</small>
          <% end %>
        </div>

        <div class="form-group">
          <%= f.label :password_confirmation, "Confirmer le mot de passe", class: "form-label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
        </div>
      </section>

      <!-- ====== SECTION 2 : ENTREPRISE ====== -->
      <section class="profile-section">
        <h2 class="profile-section-title">Mon entreprise</h2>

        <div class="form-group">
          <%= f.label :company_name, "Nom de l'entreprise", class: "form-label" %>
          <%= f.text_field :company_name, class: "form-control", placeholder: "Atelier Marie Couture" %>
        </div>

        <div class="form-group">
          <%= f.label :phone, "Numéro de téléphone", class: "form-label" %>
          <%= f.telephone_field :phone, class: "form-control", placeholder: "06 12 34 56 78" %>
        </div>
      </section>

      <!-- ====== VALIDATION ====== -->
      <section class="profile-section">
        <div class="form-group">
          <%= f.label :current_password, "Mot de passe actuel", class: "form-label" %>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control", placeholder: "Requis pour valider les changements" %>
          <small class="form-hint">Nécessaire pour confirmer toute modification.</small>
        </div>

        <%= f.submit "Enregistrer les modifications", class: "btn-profile-save" %>
      </section>
    <% end %>
  </div>
</div>
