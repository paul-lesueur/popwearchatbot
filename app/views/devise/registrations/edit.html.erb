<div class="profile-page">
  <div class="profile-card">
    <h1 class="profile-title">Mon profil</h1>
    <p class="profile-subtitle">Gérez vos informations de connexion</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "profile-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="form-group">
        <%= f.label :email, "Adresse email", class: "form-label" %>
        <%= f.email_field :email, class: "form-control", autocomplete: "email" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <p class="form-hint">Actuellement en attente de confirmation pour : <%= resource.unconfirmed_email %></p>
      <% end %>

      <hr class="profile-divider">

      <div class="form-group">
        <%= f.label :password, "Nouveau mot de passe", class: "form-label" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-control", placeholder: "Laisser vide pour ne pas changer" %>
        <% if @minimum_password_length %>
          <small class="form-hint"><%= @minimum_password_length %> caractères minimum</small>
        <% end %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirmer le mot de passe", class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
      </div>

      <hr class="profile-divider">

      <div class="form-group">
        <%= f.label :current_password, "Mot de passe actuel", class: "form-label" %>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control", placeholder: "Requis pour valider les changements" %>
        <small class="form-hint">Nous avons besoin de votre mot de passe actuel pour confirmer les modifications.</small>
      </div>

      <%= f.submit "Enregistrer les modifications", class: "btn-profile-save" %>
    <% end %>
  </div>
</div>
