<div class="container deadline-page">
  <div class="deadline-header">
    <h1>Nouvelle échéance</h1>

    <%= link_to deadlines_path, class: "btn-back" do %>
      ← Retour à la liste
    <% end %>
  </div>

  <div class="popwear-card ai-prefill-card">
    <div class="ai-badge">✨ IA Popwear</div>

    <h2>Créer avec l'IA</h2>

    <p>
      Décris ta tâche. Popwear remplit le formulaire, tu valides.
    </p>

    <%= form_with url: prefill_deadlines_path,
                  method: :post,
                  local: true,
                  data: { turbo: false } do %>
      <div class="form-group">
        <%= label_tag :task_description, "Tâche à créer", class: "form-label" %>

        <%= text_area_tag :task_description,
                          @ai_task_description,
                          rows: 2,
                          required: true,
                          class: "form-control",
                          placeholder: "Ex : Prévenir Mme Dupont que sa veste aura 2 jours de retard.",
                          oninvalid: "this.setCustomValidity('Ajoute une tâche avant de lancer l'IA.')",
                          oninput: "this.setCustomValidity('')" %>

        <small class="ai-helper-text">
          Plus c'est précis, meilleur sera le pré-remplissage.
        </small>
      </div>

      <%= submit_tag "Préparer avec l'IA", class: "btn btn-dark" %>
    <% end %>
  </div>

  <div class="popwear-card deadline-form-card">
    <%= render "form" %>
  </div>
</div>
