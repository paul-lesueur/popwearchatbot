<%= form_with model: @deadline, class: "deadline-form" do |f| %>
  <% if @deadline.errors.any? %>
    <div class="form-errors">
      <h2>
        <%= pluralize(@deadline.errors.count, "erreur") %> ont empêché l'enregistrement :
      </h2>

      <ul>
        <% @deadline.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :title, "Titre" %>

    <%= f.text_field :title,
      required: true,
      class: "form-control",
      placeholder: "Ex : Prévenir Mme Dupont" %>
  </div>

  <div class="form-group">
    <%= f.label :description, "Description" %>

    <%= f.text_area :description,
      class: "form-control",
      rows: 2,
      placeholder: "Décris rapidement la tâche à réaliser..." %>
  </div>

  <div class="form-row form-row-2">
    <div class="form-group">
      <%= f.label :category, "Catégorie" %>

      <%= f.select :category,
        Deadline.categories.keys.map { |k| [k.humanize, k] },
        { prompt: "Choisir une catégorie" },
        class: "form-select" %>
    </div>

    <div class="form-group">
      <%= f.label :due_date, "Date d'échéance" %>

      <%= f.date_field :due_date,
        class: "form-control" %>
    </div>
  </div>

  <div class="form-row form-row-2">
    <div class="form-group">
      <%= f.label :estimated_duration, "Durée estimée" %>

      <%= f.number_field :estimated_duration,
        class: "form-control",
        min: 0,
        step: 1,
        placeholder: "Ex : 45 min" %>
    </div>

    <div class="form-group">
      <%= f.label :status, "Statut" %>

      <%= f.select :status,
        Deadline.statuses.keys.map { |k| [k.humanize, k] },
        {},
        class: "form-select" %>
    </div>
  </div>

  <div class="form-actions">
    <%= f.submit @deadline.new_record? ? "Créer une échéance" : "Mettre à jour",
      class: "btn btn-dark" %>

    <%= link_to "Retour à la liste",
      deadlines_path,
      class: "btn btn-outline-dark" %>
  </div>
<% end %>

<% if @deadline.persisted? %>
  <div class="ai-estimation-card mt-4">
    <h2>Estimation IA</h2>

    <p>
      Demande à l'IA d'estimer le temps nécessaire pour cette échéance.
    </p>

    <%= button_to "Demander une estimation",
      estimate_duration_deadline_path(@deadline),
      method: :patch,
      class: "btn btn-outline-dark",
      form: { data: { turbo: false } } %>
  </div>
<% end %>
