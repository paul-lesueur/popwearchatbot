<div class="container mt-4 deadline-form-page">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Nouvelle échéance</h1>

    <%= link_to "← Retour à la liste", deadlines_path, class: "btn btn-outline-dark" %>
  </div>

  <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
    <h2 class="h5 mb-2">Pré-remplissage IA</h2>

    <p class="text-muted mb-3">
      Décris rapidement ta tâche, et l'IA remplira le formulaire pour toi.
    </p>

    <%= form_with url: prefill_deadlines_path,
                  method: :post,
                  local: true,
                  data: { turbo: false } do %>
      <div class="mb-3">
        <%= label_tag :task_description, "Décris ta tâche", class: "form-label fw-semibold" %>

        <%= text_area_tag :task_description,
                          @ai_task_description,
                          rows: 4,
                          class: "form-control",
                          placeholder: "Ex : Prévenir le client que sa commande aura 2 jours de retard à cause d'un problème à l'atelier." %>
      </div>

      <%= submit_tag "Pré-remplir avec l'IA", class: "btn btn-dark" %>
    <% end %>
  </div>

  <div class="deadline-form-card">
    <%= render "form" %>
  </div>
</div>
