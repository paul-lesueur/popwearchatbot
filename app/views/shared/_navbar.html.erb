<% unless current_page?(root_path) %>
  <nav class="navbar-popwear">
    <div class="navbar-container container">
      <%= link_to root_path, class: "navbar-logo" do %>
        <%= image_tag "popwear-pro-logo.png", alt: "Popwear", height: 48 %>
      <% end %>

      <div class="navbar-links">
        <% if user_signed_in? %>
          <span class="navbar-greeting">
            Bonjour <%= current_user.first_name.presence || current_user.email.split("@").first %> 👋
          </span>

          <%= link_to "Mes échéances", deadlines_path, class: "navbar-link" %>

          <%= link_to "Mon profil",
              edit_user_registration_path,
              class: "navbar-link" %>

          <%= link_to "Déconnexion",
              destroy_user_session_path,
              data: { turbo_method: :delete },
              class: "navbar-link navbar-logout" %>
        <% else %>
          <%= link_to "Connexion",
              new_user_session_path,
              class: "navbar-link" %>

          <%= link_to "Inscription",
              new_user_registration_path,
              class: "navbar-btn" %>
        <% end %>
      </div>
    </div>
  </nav>
<% end %>
