<%
  today = Date.current
  due_date = @deadline.due_date
  days_left = due_date.present? ? (due_date - today).to_i : nil

  if @deadline.status == "done"
    urgency_class = "urgency-green"
    urgency_label = "Terminée"
  elsif due_date.blank?
    urgency_class = "urgency-orange"
    urgency_label = "À planifier"
  elsif due_date < today
    urgency_class = "urgency-red"
    urgency_label = "En retard"
  elsif due_date == today
    urgency_class = "urgency-red"
    urgency_label = "Aujourd'hui"
  elsif due_date <= today + 7
    urgency_class = "urgency-orange"
    urgency_label = "Cette semaine"
  else
    urgency_class = "urgency-green"
    urgency_label = "Dans #{days_left} jours"
  end
%>

<div class="container my-5 deadline-show">
  <div class="show-back-link mb-4">
    <%= link_to "← Retour à la liste", deadlines_path, class: "btn btn-outline-dark" %>
  </div>

  <div class="deadline-show-card <%= urgency_class %>">
    <div class="deadline-show-header">
      <div>
        <div class="deadline-meta mb-2">
          <span class="badge bg-secondary"><%= @deadline.category.humanize %></span>
          <span class="badge bg-light"><%= status_label(@deadline.status) %></span>
          <span class="urgency-badge <%= urgency_class %>"><%= urgency_label %></span>
        </div>

        <h1><%= @deadline.title %></h1>
      </div>

      <div class="deadline-header-side">
        <div class="deadline-urgency-display <%= urgency_class %>">
          <span><%= urgency_label %></span>

          <% if due_date.present? %>
            <small><%= l(due_date, format: :long) %></small>
          <% end %>
        </div>

        <div class="deadline-actions">
          <button class="btn btn-outline-dark btn-sm"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#edit-deadline-form"
                  aria-expanded="false"
                  aria-controls="edit-deadline-form">
            Modifier
          </button>

          <%= button_to "Supprimer",
                        deadline_path(@deadline),
                        method: :delete,
                        class: "btn btn-outline-danger btn-sm",
                        form: { data: { turbo_confirm: "Supprimer cette échéance ?" } } %>
        </div>
      </div>
    </div>

    <div class="deadline-info-card">
      <h2>Informations</h2>

      <% if @deadline.description.present? %>
        <div class="deadline-info-description">
          <span class="info-label">Description</span>
          <p><%= @deadline.description %></p>
        </div>
      <% end %>

      <div class="deadline-info-grid">
        <div>
          <span class="info-label">Catégorie</span>
          <p><%= @deadline.category.humanize %></p>
        </div>

        <div>
          <span class="info-label">Date limite</span>
          <p>
            <% if due_date.present? %>
              <%= l(due_date, format: :long) %>
            <% else %>
              Non définie
            <% end %>
          </p>
        </div>

        <div>
          <span class="info-label">Statut</span>
          <p><%= status_label(@deadline.status) %></p>
        </div>

        <div>
          <span class="info-label">Durée estimée</span>
          <p>
            <% if @deadline.estimated_duration.present? %>
              <%= @deadline.estimated_duration %> minutes
            <% else %>
              Non estimée
            <% end %>
          </p>
        </div>
      </div>
    </div>

    <div class="collapse" id="edit-deadline-form">
      <div class="edit-deadline-panel">
        <h2>Modifier l'échéance</h2>

        <%= form_with model: @deadline, local: true do |f| %>
          <div class="mb-3">
            <%= f.label :title, "Titre", class: "form-label" %>
            <%= f.text_field :title, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :description, "Description", class: "form-label" %>
            <%= f.text_area :description, rows: 3, class: "form-control" %>
          </div>

          <div class="show-form-grid">
            <div class="mb-3">
              <%= f.label :category, "Catégorie", class: "form-label" %>
              <%= f.select :category,
                           Deadline.categories.keys.map { |k| [k.humanize, k] },
                           {},
                           class: "form-select" %>
            </div>

            <div class="mb-3">
              <%= f.label :due_date, "Date limite", class: "form-label" %>
              <%= f.date_field :due_date, class: "form-control" %>
            </div>
          </div>

          <div class="show-form-grid">
            <div class="mb-3">
              <%= f.label :status, "Statut", class: "form-label" %>
              <%= f.select :status,
                           Deadline.statuses.keys.map { |k| [status_label(k), k] },
                           {},
                           class: "form-select" %>
            </div>

            <div class="mb-3">
              <%= f.label :estimated_duration, "Durée estimée", class: "form-label" %>
              <%= f.number_field :estimated_duration,
                                 class: "form-control",
                                 min: 0,
                                 step: 1 %>
            </div>
          </div>

          <%= f.submit "Enregistrer les modifications", class: "btn btn-dark" %>
        <% end %>
      </div>
    </div>

    <div class="ai-panel">
      <div class="ai-badge">✨ IA Popwear</div>

      <h2>Estimation IA de la durée</h2>

      <p>
        Popwear analyse la tâche et propose une première estimation.
      </p>

      <%= form_with url: estimate_duration_deadline_path(@deadline),
                    method: :patch,
                    local: true,
                    data: { turbo: false } do %>
        <%= submit_tag "Demander une estimation", class: "btn btn-dark" %>
      <% end %>
    </div>

    <div class="ai-panel">
      <div class="ai-badge">✨ IA Popwear</div>

      <h2>Message client</h2>

      <p>
        Popwear génère un message professionnel prêt à envoyer.
      </p>

      <%= button_to(
        @client_message.present? ? "Régénérer le message" : "Générer un message",
        deadline_chats_path(@deadline),
        method: :post,
        class: "btn btn-dark"
      ) %>

      <% if @client_message.present? %>
        <div class="generated-message-card mt-4" data-controller="clipboard">
          <div class="generated-message-header">
            <h3>Message généré</h3>

            <button type="button"
                    class="btn btn-outline-dark btn-sm"
                    data-clipboard-target="button"
                    data-action="click->clipboard#copy">
              Copier
            </button>
          </div>

          <div id="client-message-content"
               class="generated-message-content"
               data-clipboard-target="source">
            <%= simple_format(@client_message.content) %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
