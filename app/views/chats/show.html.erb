<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><%= @deadline.title %></h1>

    <%= link_to "← Retour aux échéances", deadlines_path, class: "btn btn-outline-dark" %>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="mb-3">
        <span class="badge bg-secondary">
          <%= @deadline.category&.humanize || "Non classé" %>
        </span>

        <span class="badge bg-light text-dark">
          <%= @deadline.status&.humanize || "Todo" %>
        </span>
      </div>

      <% if @deadline.description.present? %>
        <p class="card-text">
          <%= @deadline.description %>
        </p>
      <% end %>

      <p class="text-muted">
        📅 Date limite :
        <strong><%= l(@deadline.due_date, format: :long) if @deadline.due_date.present? %></strong>
      </p>

      <% if @deadline.estimated_duration.present? %>
        <p class="text-muted">
          ⏱️ Durée estimée :
          <strong><%= @deadline.estimated_duration %> minutes</strong>
        </p>
      <% end %>

      <div class="d-flex gap-2 flex-wrap mt-4">
        <%= link_to "Modifier", edit_deadline_path(@deadline), class: "btn btn-outline-dark" %>

        <%= button_to "Estimer la durée avec l'IA",
          estimate_duration_deadline_path(@deadline),
          method: :patch,
          class: "btn btn-outline-primary" %>

        <%= button_to "Générer un message client",
          deadline_chats_path(@deadline),
          method: :post,
          class: "btn btn-primary" %>

        <%= button_to "Supprimer",
          deadline_path(@deadline),
          method: :delete,
          class: "btn btn-outline-danger",
          form: { data: { turbo_confirm: "Supprimer cette échéance ?" } } %>
      </div>
    </div>
  </div>
</div>
