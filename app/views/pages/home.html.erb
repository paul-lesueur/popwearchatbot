

<div class="home-page">


  <div class="home-content">

    <%= image_tag "home-illustration.png", alt: "", class: "home-illustration" %>

    <h1 class="home-title">
      <%= image_tag "popwear-pro-logo.png", alt: "Popwear", class: "home-logo-img" %>
    </h1>
    <%= image_tag "popwear-pro-logo.png", alt: "Popwear", height: 96, class: "home-title" %>

    <p class="home-subtitle">
      L'assistant IA qui aide les couturiers, retoucheurs et cordonniers à gérer leurs échéances.
    </p>

    <p class="home-description">
      Priorisez vos tâches, estimez vos délais et évitez les retards grâce à l'intelligence artificielle.
    </p>

    <% if user_signed_in? %>
      <%= link_to "Commencer →", deadlines_path, class: "btn-home-primary" %>
    <% else %>
      <%= link_to "Commencer →", new_user_session_path, class: "btn-home-primary" %>
    <% end %>

  </div>
</div>
