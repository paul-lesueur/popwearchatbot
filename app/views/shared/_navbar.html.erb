<% unless current_page?(root_path) %>
<nav class="navbar-popwear">
  <div class="navbar-container">

    <!-- Logo -->
    <%= link_to root_path, class: "navbar-logo" do %>
      <span class="logo-dot-small"></span>
      Popwear
    <% end %>

    <!-- Liens -->
    <div class="navbar-links">
      <% if user_signed_in? %>
        <%= link_to "Mes échéances", deadlines_path, class: "navbar-link" %>
        <%= link_to "Déconnexion", destroy_user_session_path,
            data: { turbo_method: :delete },
            class: "navbar-link navbar-link-logout" %>
      <% else %>
        <%= link_to "Connexion", new_user_session_path, class: "navbar-link" %>
        <%= link_to "Inscription", new_user_registration_path, class: "navbar-btn" %>
      <% end %>
    </div>

  </div>
</nav>
<% end %>
