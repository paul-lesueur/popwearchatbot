<h1><%= @deadline.title %></h1>

<p>
  <strong>Description :</strong>
  <%= @deadline.description %>
</p>

<p>
  <strong>Catégorie :</strong>
  <%= @deadline.category %>
</p>

<p>
  <strong>Date limite :</strong>
  <%= @deadline.due_date %>
</p>

<% if @deadline.estimated_duration.present? %>
  <p>
    <strong>Durée estimée sauvegardée :</strong>
    <%= @deadline.estimated_duration %> minutes
  </p>
<% end %>

<hr>

<h2>Estimation IA de la durée</h2>

<p>
  L’IA va analyser la tâche, poser les questions de précision utiles,
  puis proposer une première estimation de durée.
</p>

<%= form_with url: estimate_duration_deadline_path(@deadline),
              method: :patch,
              local: true,
              data: { turbo: false } do %>
  <%= submit_tag "Demander une estimation à l’IA", class: "btn btn-primary" %>
<% end %>

<% if @ai_response.present? %>
  <hr>

  <h3>Réponse de l’IA</h3>

  <div>
    <%= simple_format(@ai_response) %>
  </div>
<% end %>
<dl>
  <dt>Catégorie</dt>
  <dd><%= @deadline.category.humanize %></dd>

  <dt>Date d'échéance</dt>
  <dd><%= l(@deadline.due_date, format: :long) %></dd>

  <dt>Statut</dt>
  <dd><%= @deadline.status.humanize %></dd>

  <% if @deadline.description.present? %>
    <dt>Description</dt>
    <dd><%= simple_format(@deadline.description) %></dd>
  <% end %>
</dl>

<%= link_to "Modifier", edit_deadline_path(@deadline) %>
<%= button_to "Supprimer", deadline_path(@deadline), method: :delete, form: { data: { turbo_confirm: "Supprimer cette échéance ?" } } %>
<%= link_to "Retour à la liste", deadlines_path %>
